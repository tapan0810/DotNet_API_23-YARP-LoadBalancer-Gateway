{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "server=MACHINE99\\SQLEXPRESS;database=HotelDb23;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "ReverseProxy": {
    "Routes": {
      "hotelRoute": {
        "ClusterId": "hotelCluster",
        "Match": {
          "Path": "/api/hotel/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "hotelCluster": {
        "LoadBalancingPolicy": "RoundRobin",

        "Destinations": {
